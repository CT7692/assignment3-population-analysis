int* getData(const int);
int getTotal(const int*, int);
int getAverage(const int*, int, int);
int getMax(const int*, const int);
void displayForward(const int*, int);
void displayBackward(const int*, int);
void bubbleSort(int*, int);


int main()
{
	const int SIZE = 16;
	int *ptr = new int [SIZE];
	int total, average, max;

	ptr = getData(SIZE);

	cout << "The following data was read from the input file." << endl;
	displayForward(ptr, SIZE);

	cout << "\n\nDisplay forward:" << endl;
