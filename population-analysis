	cout << "\n\nDisplay backward: \n" << endl;
	displayBackward(ptr, SIZE);

	cout << "\n\nThe total population is: ";
	total = getTotal(ptr, SIZE);
	cout << total << endl;

	cout << "\n\nThe average is: ";
	average = getAverage(ptr, SIZE, total);
	cout << average << endl;

	cout << "\n\nThe maximum is: ";
	max = getMax(ptr, SIZE);
	cout << max << endl;

	bubbleSort(ptr, SIZE);

	cout << "\n\nAfter sorting, display forward:" << endl;
	displayForward(ptr, SIZE);

	cout << "\n\nAfter sorting, display backwards:\n" << endl;
	displayBackward(ptr, SIZE);


	delete[] ptr;
	ptr = nullptr;
	return 0;
}

int * getData(const int SIZE)
{
	ifstream pop;
	int *ptr = nullptr;

	pop.open("population.txt");

	if (SIZE <= 0)
		return nullptr;

	ptr = new int[SIZE];

	for (int i = 0; i < SIZE; i++)
	{
		pop >> ptr[i];
		
	}
	pop.close();

	
	return ptr;
	
}

int getTotal(const int * ptr, int SIZE)
{
	int total = 0;
	
	for (int i = 0; i < SIZE; i++)
	{
		total += *ptr;
		ptr++;
	}

	return total;
}

int getAverage(const int * ptr, int SIZE, int tot)
{
	int avg;

	avg = tot / SIZE;

	return avg;
}

void displayForward(const int * ptr, int SIZE)
{
	
	for (int i = 0; i < SIZE; i++)
	{
		if (i % 4 == 0)
		{
			cout << endl;
		}


		cout << setw(10) << left << *ptr << " ";
		ptr++;

	}

}

int getMax(const int * ptr, int SIZE)
{
	int max = 0;

	for (int i = 0; i < SIZE; i++)
	{
		if (max < ptr[i])
		{
			max = ptr[i];
		}
	}
	return max;
}

void displayBackward(const int * ptr, int SIZE)
{	
	for (int i = (SIZE - 1); i >= 0; i--)
	{
			cout << setw(10) << left << *(ptr + i) << " ";
			if (i != 0 && i % 4 == 0)
			{
				cout << endl;
			}
	}
	
}

void swap(int* ap, int* bp)
{
	int swa = *ap;
	*ap = *bp;
	*bp = swa;
}

void bubbleSort(int* ptr, int SIZE)
{
	int swa;
	for (int i = (SIZE - 1); i > 0; i--)
	{
		for (int j = 0; j < i; j++)
		{
			if (ptr[j] > ptr[j + 1])
			{
				swa = ptr[j];
				ptr[j] = ptr[j + 1];
				ptr[j + 1] = swa;
			}
		}
	}
}

